{
  "name": "vsc-snippet-catalog",
  "displayName": "Command Vault",
  "description": "VS Code extension scaffold for the Command Vault MVP.",
  "version": "0.0.1",
  "publisher": "albertmacmini",
  "private": true,
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "build": "tsc -p ./tsconfig.json",
    "compile": "npm run build",
    "clean": "rm -rf out coverage",
    "test": "node --test ./test/**/*.test.js",
    "test:vitest": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^24.0.1",
    "@types/vscode": "^1.101.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  }
}
