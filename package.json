{
  "name": "vsc-snippet-catalog",
  "displayName": "Command Vault",
  "description": "VS Code extension scaffold for the Command Vault MVP.",
  "version": "0.0.1",
  "publisher": "albertmacmini",
  "private": true,
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:commandVault.commands",
    "onCommand:commandVault.createCommand",
    "onCommand:commandVault.editCommand",
    "onCommand:commandVault.deleteCommand"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "commandVault",
          "title": "Command Vault",
          "icon": "resources/command-vault.svg"
        }
      ]
    },
    "views": {
      "commandVault": [
        {
          "id": "commandVault.commands",
          "name": "Commands"
        }
      ]
    },
    "commands": [
      {
        "command": "commandVault.createCommand",
        "title": "Command Vault: Create Command"
      },
      {
        "command": "commandVault.editCommand",
        "title": "Command Vault: Edit Command"
      },
      {
        "command": "commandVault.deleteCommand",
        "title": "Command Vault: Delete Command"
      }
    ]
  },
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "compile": "npm run build",
    "clean": "rm -rf out coverage",
    "test": "node --test ./test/**/*.test.js",
    "test:vitest": "node --no-warnings --test --experimental-strip-types ./src/extension.test.ts ./src/command-vault/model.test.ts ./src/command-vault/repository.test.ts ./src/command-vault/execution.test.ts ./src/command-vault/create-command.test.ts ./src/command-vault/edit-delete-command.test.ts ./src/command-vault/sidebar.test.ts"
  },
  "devDependencies": {
    "@types/node": "^24.0.1",
    "@types/vscode": "^1.101.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  }
}
